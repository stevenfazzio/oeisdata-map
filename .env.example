# Required for pipeline stages 03 (enrich) and 06 (label)
ANTHROPIC_API_KEY=your_anthropic_key_here

# Required for pipeline stages 04 (embed) and 06 (label)
CO_API_KEY=your_cohere_key_here

# Optional — scope selector for stage 02: core | curated | all
# core    = 183 sequences with the OEIS "core" keyword (v0 smoke test)
# curated = ~25k highest-quality sequences (v1 publishable map)
# all     = all 394k sequences (stretch; stage 03 LLM enrichment is auto-skipped)
OEIS_SCOPE=core
